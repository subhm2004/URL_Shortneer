# Root .env — read by docker-compose only. `npm run dev` in app/ and frontend/
# reads their own .env files instead.
#
# `make up` copies this to .env on first run and fills in JWT_SECRET.

# Postgres connection string. Any provider — Neon, Supabase, Railway, RDS.
# Leave EMPTY to run a Postgres container alongside the app instead:  make up-local
DATABASE_URL=

# Public origin the stack is reachable at. Three things use it:
#   · the backend mints short links against it  (${PUBLIC_BASE_URL}/abc123)
#   · it is the backend's allowed CORS origin
#   · the frontend is BUILT against it — Next inlines NEXT_PUBLIC_* at build time,
#     so changing this means rebuilding the image, not just restarting it.
PUBLIC_BASE_URL=http://localhost:3000

# Host port the frontend listens on. Next serves a Node process on 3000, where
# the old Vite build was static files behind nginx on 80.
UI_PORT=3000

# JWT signing secret. Leave empty and `make up` / `up.ps1` will generate one on
# first start, then reuse it. Changing it later invalidates every session.
JWT_SECRET=

# Short-code generation Strategy: nanoid | base62
SHORT_CODE_STRATEGY=nanoid
