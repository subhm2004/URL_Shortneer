# Postgres connection string. Any provider works — Neon, Supabase, Railway, RDS.
# TLS is turned on automatically for non-local hosts.
#
# Leave this EMPTY to run a Postgres container alongside the app instead:
#   make up-local
DATABASE_URL=

# Public URL where Trunc will be reachable. Used to mint short links
# (${PUBLIC_BASE_URL}/abc123) and as the CORS origin.
PUBLIC_BASE_URL=http://localhost

# Host port the frontend (nginx) will listen on. Change to 8080 if 80 is taken.
UI_PORT=80

# JWT signing secret. Leave empty to have `make up` / `up.ps1` auto-generate one
# on first start. The value is written to .env and reused on subsequent starts.
JWT_SECRET=

# Short-code generation Strategy: nanoid | base62
SHORT_CODE_STRATEGY=nanoid
