# ---- required -------------------------------------------------------------

# Postgres connection string. Works with Neon / Supabase / Railway / local Docker.
# TLS is enabled automatically for any non-local host.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Signing key for auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Changing this after users have registered invalidates every existing session.
JWT_SECRET=

# ---- server ---------------------------------------------------------------

PORT=5000
NODE_ENV=development

# Public origin short links are minted against, e.g. http://localhost:5000/abc123
BASE_URL=http://localhost:5000

# Comma-separated CORS origins the frontend is served from.
ALLOWED_ORIGINS=http://localhost:5173

# ---- short codes ----------------------------------------------------------

# Which generation Strategy to use: nanoid | base62
SHORT_CODE_STRATEGY=nanoid
SHORT_CODE_LENGTH=8

# ---- cache ----------------------------------------------------------------

# The redirect-path cache (Decorator over UrlRepository). Set false to bypass it.
CACHE_ENABLED=true
CACHE_TTL_MS=60000

# ---- logging --------------------------------------------------------------

# error | warn | info | debug
LOG_LEVEL=debug
