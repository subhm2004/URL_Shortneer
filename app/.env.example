# ---- required -------------------------------------------------------------

# Postgres connection string. Works with Neon / Supabase / Railway / local Docker.
# TLS is enabled automatically for any non-local host.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Signing key for auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Changing this after users have registered invalidates every existing session.
JWT_SECRET=

# ---- server ---------------------------------------------------------------

PORT=5000
NODE_ENV=development

# Public origin short links are minted against, e.g. http://localhost:5000/abc123
BASE_URL=http://localhost:5000

# Comma-separated CORS origins the frontend is served from.
ALLOWED_ORIGINS=http://localhost:3000

# ---- short codes ----------------------------------------------------------

# Which generation Strategy to use: nanoid | base62
SHORT_CODE_STRATEGY=nanoid
SHORT_CODE_LENGTH=8

# ---- cache ----------------------------------------------------------------

# The redirect-path cache (Decorator over UrlRepository). Set false to bypass it.
CACHE_ENABLED=true
CACHE_TTL_MS=60000

# ---- logging --------------------------------------------------------------

# error | warn | info | debug
LOG_LEVEL=debug

# ---- Google OAuth (optional) -----------------------------------------------

# Leave these empty and the whole feature switches off cleanly: the routes aren't
# mounted, and the frontend hides the button because /api/auth/providers says so.
#
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# (Application type: Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match an "Authorized redirect URI" in that console entry BYTE FOR BYTE.
# A mismatch is the #1 cause of failure here, and Google's only clue is the
# unhelpful "redirect_uri_mismatch".
#   dev  → http://localhost:5050/api/auth/google/callback
#   prod → https://trunc-app-api.onrender.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5050/api/auth/google/callback

# Where the browser is sent back to once we've issued our own JWT.
FRONTEND_URL=http://localhost:3000
