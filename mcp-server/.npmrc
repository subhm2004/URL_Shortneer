# TypeScript and @types/* are build-time tools, so they belong in
# devDependencies — shipping a compiler to production would be wrong.
#
# But a host that sets NODE_ENV=production (Render, Heroku, …) makes `npm install`
# skip devDependencies entirely, and the build then has no compiler and no type
# declarations. The usual answer is to remember `npm install --include=dev` in the
# host's build command, which is one more thing to get wrong in a dashboard.
#
# Pinning it here means a plain `npm install` builds correctly anywhere.
include=dev
