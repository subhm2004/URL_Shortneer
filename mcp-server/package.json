{
  "name": "trunc-mcp",
  "version": "0.3.0",
  "description": "MCP server for Trunc (URL shortener) \u2014 stdio + HTTP",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx watch src/http.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:http": "node dist/http.js",
    "start:stdio": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
