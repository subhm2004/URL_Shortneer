# Backend origin.
#
# Local dev: leave this at localhost:5050 — next.config.ts proxies /api to it, so
# the browser makes same-origin requests and CORS never enters the picture.
#
# Production (Vercel): set this to your Render backend, e.g.
#   NEXT_PUBLIC_API_URL=https://trunc-app-api.onrender.com
# and make sure that origin is in the backend's ALLOWED_ORIGINS.
#
# NEXT_PUBLIC_ vars are inlined at BUILD time — change one and you must redeploy.
NEXT_PUBLIC_API_URL=http://localhost:5050

# Public URL of the hosted MCP server. The /mcp page shows this in the
# copy-paste client config.
NEXT_PUBLIC_MCP_URL=https://trunc-mcp-server.onrender.com/mcp
