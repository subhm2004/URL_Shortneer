# ---- development ------------------------------------------------------------
# Leave NEXT_PUBLIC_API_URL unset. The browser then fetches /api/… (same-origin)
# and next.config.ts forwards it to BACKEND_ORIGIN — no CORS involved.
BACKEND_ORIGIN=http://localhost:5050
NEXT_PUBLIC_MCP_URL=http://localhost:3001/mcp

# ---- production (Vercel) ----------------------------------------------------
# Vercel and Render are different origins, so here the browser DOES call the
# backend directly and NEXT_PUBLIC_API_URL must be set:
#
#   NEXT_PUBLIC_API_URL=https://trunc-app-api.onrender.com
#   NEXT_PUBLIC_MCP_URL=https://trunc-mcp-server.onrender.com/mcp
#
# That origin must appear in the backend's ALLOWED_ORIGINS.
# NEXT_PUBLIC_* vars are inlined at BUILD time — change one, redeploy.

# ---- Chat assistant (Groq) --------------------------------------------------
# Server-only — deliberately NOT NEXT_PUBLIC_, or the key would be baked into the
# browser bundle for anyone to take. Free key at https://console.groq.com/keys
# Leave empty and /chat returns a clean 503 saying it isn't configured.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
MCP_SERVER_URL=http://localhost:3001/mcp
